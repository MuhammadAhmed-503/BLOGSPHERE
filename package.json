{
  "name": "blog-saas-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace scripts for separated frontend and backend packages",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run preview",
    "lint": "npm --prefix frontend run lint",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:seed": "npm --prefix backend run seed",
    "backend:reset:views": "npm --prefix backend run reset:views"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}
